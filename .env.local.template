# AnswerRank AI — environment template. Copy to .env.local and fill in.
# All names are UPPERCASE (Next.js requires the exact NEXT_PUBLIC_ prefix to
# expose vars to the browser). Code, .env.local, and Vercel all use these names.

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_AI_API_KEY=

# ─── SerpAPI — Google AI Overviews (replaces Google PSE, deprecated Jan 2026) ───
# Free tier = 250 searches/month. Used by the SerpAPI two-call AIO flow.
SERPAPI_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_AUDIT_297=
STRIPE_PRICE_DFY_1497=

# ─── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@answerrank.ai

# ─── App / Cron ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://answerrank.ai
CRON_SECRET=

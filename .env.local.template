# AnswerRank AI — environment template. Copy to .env.local and fill in.
# NOTE: casing is intentional. Supabase/Stripe keys are lowercase (migrated for
# Vercel compatibility); the code reads these exact names. Do not "normalize".

# ─── Supabase (lowercase) ──────────────────────────────────────────────────────
next_public_supabase_url=
next_public_supabase_anon_key=
supabase_service_role_key=

# ─── AI Providers (uppercase) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_AI_API_KEY=

# ─── SerpAPI — Google AI Overviews (replaces Google PSE, deprecated Jan 2026) ───
# Free tier = 250 searches/month. Used by the SerpAPI two-call AIO flow.
SERPAPI_KEY=

# ─── Stripe (lowercase) ────────────────────────────────────────────────────────
stripe_secret_key=
stripe_webhook_secret=
stripe_price_audit_297=
stripe_price_dfy_1497=

# ─── Resend (uppercase) ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@answerrank.ai

# ─── App / Cron (uppercase) ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://answerrank.ai
CRON_SECRET=
